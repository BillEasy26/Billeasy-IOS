// Copie este arquivo para `Secrets.xcconfig` e preencha apenas em ambiente local/CI.
// Esse arquivo de exemplo pode ser versionado; o arquivo real fica fora do Git.

AI_SERVICE_TOKEN = cole_o_token_service_to_service_aqui
GOOGLE_OAUTH_CLIENT_ID = cole_o_client_id_do_oauth_ios_aqui.apps.googleusercontent.com

// Se eu precisar apontar o app para outro frontend, posso sobrescrever aqui.
// FRONTEND_BASE_URL = http:/$()/localhost:3000

// Se eu precisar sobrescrever as bases em um ambiente específico, posso usar:
// API_BASE_URL = https:/$()/api.billeasy.com.br
// AI_SERVICE_BASE_URL = https:/$()/billeasy-ai-service.vercel.app
// APP_AUTH_MODE = remote
// GOOGLE_OAUTH_REDIRECT_SCHEME = br.com.billeasy
// GOOGLE_OAUTH_REDIRECT_PATH = /oauth2redirect/google
